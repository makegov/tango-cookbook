# Copy to .env and fill in. `just` auto-loads this into recipe environments.
TANGO_API_KEY=

# Only required for examples/ (e.g. the opportunities agent). Notebooks don't need it.
ANTHROPIC_API_KEY=

# Only required for examples/webhook-receiver/server.py.
# Printed when you create the endpoint via examples/webhook-receiver/register.py.
TANGO_WEBHOOK_SECRET=

# Optional. Used by examples/saved-search-watcher and examples/webhook-receiver
# when a profile / receiver is configured with the `slack` sink.
SLACK_WEBHOOK_URL=
