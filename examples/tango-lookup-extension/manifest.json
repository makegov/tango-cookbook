{
  "manifest_version": 3,
  "name": "Tango Lookup",
  "version": "0.1.0",
  "description": "Quick lookup for entities and contracts in Tango",
  "permissions": [
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "https://tango.makegov.com/*"
  ],
  "optional_host_permissions": [
    "*://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
